# Famoir Frontend Environment Variables
# Copy to .env.local and fill in your Firebase project values

# Backend connection
VITE_WS_URL=ws://localhost:8000/chat
VITE_API_BASE=http://localhost:8000

# Firebase Auth (get these from Firebase Console → Project Settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Dev mode: set to "true" to skip auth and use a mock user (for local testing)
VITE_DEV_MODE=true
