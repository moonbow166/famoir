# ─── Famoir Backend Environment Variables ─────────────────
# Copy to .env and fill in your values

# Google / Gemini
GOOGLE_API_KEY=              # Gemini API key (required)
GOOGLE_CLOUD_PROJECT=        # GCP project ID (for Firestore)

# Server
PORT=8000                    # Server port (Cloud Run injects this)
FRONTEND_URL=http://localhost:5173  # CORS origin; use * for production (same-origin)

# Auth
DEV_MODE=true                # true = skip Firebase auth (local dev); false = enforce tokens
